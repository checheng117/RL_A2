# Project outputs (keep structure via .gitkeep)
outputs/checkpoints/**
outputs/logs/**
outputs/predictions/**
outputs/metrics/**
outputs/examples/**
outputs/report_assets/**
!outputs/checkpoints/.gitkeep
!outputs/logs/.gitkeep
!outputs/predictions/.gitkeep
!outputs/metrics/.gitkeep
!outputs/examples/.gitkeep
!outputs/report_assets/.gitkeep

# Data (user-provided; keep dirs)
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
data/splits/*
!data/splits/.gitkeep
!data/splits/split_manifest.json

